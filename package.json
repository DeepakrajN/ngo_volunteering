{
  "name": "ngo-volunteer-platform",
  "version": "1.0.0",
  "description": "Helping Hands - A full-stack NGO Volunteer Platform using React, Node.js, and MongoDB",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed/seed.js",
    "seed:volunteers": "node seed/seed_volunteers.js",
    "client": "npm start --prefix client",
    "build": "npm run build --prefix client"
  },
  "keywords": [
    "ngo",
    "volunteer",
    "mern",
    "react",
    "express",
    "mongodb",
    "fullstack"
  ],
  "author": "Helping Hands Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "codemon": "^0.1.31-development",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^8.12.1",
    "mongoose": "^7.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
