{
  "name": "ngo-volunteer-platform",
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install && npm install --prefix client",
  "framework": "express",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(?!api)(.*)",
      "destination": "/public/$1"
    }
  ]
}
