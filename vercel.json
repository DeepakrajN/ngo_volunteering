{
  "buildCommand": "npm install && npm install --prefix client && npm run build --prefix client",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps && npm install --prefix client --legacy-peer-deps",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
